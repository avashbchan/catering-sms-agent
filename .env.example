# Copy this file to .env and fill in real values. Never commit .env.

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# --- Twilio ---
# Auth token is used to validate inbound webhook signatures.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# API key SID/secret are used for any outbound SMS sent by the app itself
# (Twilio's recommended alternative to using the account SID/auth token
# directly for API calls).
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=+15555550123

# --- Staff notification email ---
STAFF_EMAIL=staff@example.com

# Option A: SMTP (used if SENDGRID_API_KEY is not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Option B: SendGrid (used instead of SMTP if set)
SENDGRID_API_KEY=

# --- App ---
DATABASE_PATH=conversations.db
RESTAURANT_NAME=The Sample Kitchen
LOG_LEVEL=INFO

# Set to "true" to skip Twilio signature validation (local testing only —
# never enable in production).
SKIP_TWILIO_SIGNATURE_VALIDATION=false
